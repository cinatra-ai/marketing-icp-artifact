{
  "name": "@cinatra-ai/marketing-icp-artifact",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "src",
    "skills"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "peerDependencies": {
    "@cinatra-ai/sdk-extensions": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    }
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "artifact",
    "displayName": "Marketing ICP",
    "dependencies": [],
    "artifact": {
      "accepts": {
        "file": {
          "mimeTypes": [
            "text/markdown",
            "text/plain",
            "application/pdf"
          ]
        }
      },
      "skills": {
        "authoring": [
          "@cinatra-ai/marketing-icp-artifact:marketing-icp-author"
        ],
        "matchers": [
          "@cinatra-ai/marketing-icp-artifact:marketing-icp-matcher"
        ]
      },
      "matcherConfidenceThreshold": 0.7,
      "objectTypes": [
        {
          "type": "@cinatra-ai/marketing-icp:profile",
          "claim": "dedicated",
          "dispositions": {
            "projection": "artifact-safe",
            "pinnable": true,
            "snapshotPolicy": "content",
            "sensitivity": "normal",
            "mutability": "draftable"
          },
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        }
      ]
    }
  }
}
